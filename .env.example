# =====================================================================
# Security Compliance Dashboard - Environment Configuration
# Copy this file to ".env" and adjust values as needed.
# =====================================================================

# --- Application ---
APP_NAME=Security Compliance Dashboard
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FILE=logs/scanner.log

# --- Database ---
DATABASE_URL=sqlite:///./database/compliance.db

# --- Scanner paths (relative to project root) ---
RESOURCES_FILE=app/resources/resources.json
RULES_DIR=app/rules
FRAMEWORK_MAPPING_FILE=app/rules/framework_mapping.json

# --- Reports ---
REPORTS_DIR=reports_output

# --- Grafana (used only by docker-compose) ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
